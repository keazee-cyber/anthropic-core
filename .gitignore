# =========================================================
# 🧠  .gitignore — Projet Anthropic Core / Nexus CLI (version finale)
# =========================================================
# Adapté à un usage personnel : protège les fichiers sensibles,
# temporaires et de configuration, tout en restant concis.
# =========================================================

# --- 🐍 Environnements Python ---
venv/
.env/
claude_env/
__pycache__/
*.py[cod]

# --- 🧩 Fichiers temporaires et sauvegardes ---
*.bak
*.save
*.tmp
*.log
*~
.DS_Store
Thumbs.db

# --- 📁 Répertoires locaux ---
backups/
logs/
tmp/

# --- ⚙️ Fichiers spécifiques au projet Anthropic Core ---
anthropic_core.sh.bak
anthropic_cli.py.save
anthropic_autocomplete.sh
anthropic_completion.sh

# --- 🧰 Configurations Bash / Shell (ne jamais pousser) ---
.bash_profile
.bashrc
.bash_history
.bash_logout
.zshrc
.zsh_history
.profile
.shellrc
.aliases
.functions

# --- ⚙️ Fichiers de configuration Nexus / Anthropic CLI ---
# (Empêche la fuite de paramètres locaux et d'identifiants)
.nexus_config
.nexus_config.json
.nexus_settings
.anthropic_settings
.anthropic_settings.json
.anthropic_env
.anthropic_env.json
.anthropic_local.cfg
.anthropic_local.yaml
anthropic_user_config/
nexus_user_config/

# --- 🔐 Fichiers sensibles / secrets ---
*.key
*.pem
*.crt
*.token
*.secret
.env.local
config_local.sh

# --- 💻 Fichiers système et IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- 🧍 Fichiers de configuration utilisateur macOS/Linux ---
.config/
.local/
.cache/
.CFUserTextEncoding
.Trash/

# --- 🗃️ Sauvegardes générées par `anthropic backup` ---
# Ces fichiers sont créés automatiquement avec un timestamp,
# par ex. : backups/bash_profile_2024-05-25_172400.bak
# On les ignore pour éviter d’encombrer le dépôt.
backups/*.bak
backups/*_backup_*.bak
backups/bash_profile_*.bak
backups/*.tar.gz
